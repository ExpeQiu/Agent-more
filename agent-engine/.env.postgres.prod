# Agent编排引擎 — PostgreSQL 生产配置
# P1-T72: PostgreSQL 生产配置迁移
#
# 验收标准:
#   - 生产环境压测：100并发下查询<100ms

# ─── Database Connection ────────────────────────────────────────────────────
DATABASE_URL=postgresql://agent_engine:${POSTGRES_PASSWORD}@postgres:5432/agent_engine

# ─── PostgreSQL Tuning ─────────────────────────────────────────────────────
POSTGRES_DB=agent_engine
POSTGRES_USER=agent_engine
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# ─── Connection Pool ─────────────────────────────────────────────────────────
# Prisma connection pool — sized for 100 concurrent queries
DATABASE_POOL_SIZE=20
DATABASE_MAX_WAIT=1000
DATABASE_STATEMENT_TIMEOUT=10000

# ─── Performance Indexes (applied via migration) ───────────────────────────
# RoutingDecision table indexes are already defined in schema.prisma:
#   - queryHash
#   - sceneId
#   - createdAt
#   - sessionId (from context->>'sessionId')
#
# Additional production indexes:
# CREATE INDEX CONCURRENTLY idx_sessions_agent_id ON "Session"("agentId");
# CREATE INDEX CONCURRENTLY idx_executions_session_id ON "Execution"("sessionId");
# CREATE INDEX CONCURRENTLY idx_messages_session_id ON "Message"("sessionId");
# CREATE INDEX CONCURRENTLY idx_llm_calls_session_id ON "LLMCall"("sessionId");
