{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "noEmit": true
  },
  "include": [
    "packages/core/src/**/*",
    "packages/llm-adapters/src/**/*",
    "packages/shared-types/src/**/*",
    "packages/mcp-client/src/**/*",
    "packages/skill-adapter/src/**/*",
    "apps/server/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
